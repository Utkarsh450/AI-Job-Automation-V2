generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model User {
  id                 String   @id @default(uuid())
  firebaseUid        String?  @unique
  email              String   @unique
  name               String?
  phone              String?
  location           String?
  visaStatus         String?  // e.g. "US Citizen", "H1B", "F1 OPT", "Requires Sponsorship"
  linkedinUrl        String?
  githubUrl          String?
  portfolioUrl       String?
  isOnboarded        Boolean  @default(false)
  
  // Google OAuth for Gmail API
  googleRefreshToken String?  @db.Text
  googleAccessToken  String?  @db.Text

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  resumes            Resume[]
  preferences        UserPreference?
  appPasswords       ApplicationPassword[]
  applications       Application[]
  jobMatches         JobMatch[]
  emails             Email[]
}

model Resume {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  s3Url       String?
  // Parsed JSON extracted by Claude/Groq
  parsedData  Json?    
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserPreference {
  id                 String   @id @default(uuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Job preferences
  preferredRoles     String[]
  preferredLocations String[]
  remotePreference   String   @default("Any") // Remote, Hybrid, On-site, Any
  targetSalary       Int?

  // Application Settings
  resumeOptimization String   @default("Optimized") // Off, Optimized, Aggressive
  coverLetterOpt     String   @default("Off")       // Off, Optimized, Aggressive
  autoApprove        Boolean  @default(true)

  // Work Preferences (From Onboarding Step 3)
  openToInPerson         Boolean  @default(true)
  willingToRelocate      Boolean  @default(false)
  canStartImmediately    Boolean  @default(true)
  reliableTransportation Boolean  @default(true)
  needAccommodations     String?  // Yes, No, Prefer not to say

  // Background (From Onboarding Step 3)
  activeClearance        Boolean  @default(false)
  foreignTies            Boolean  @default(false)

  // Diversity fields (often required in ATS)
  gender             String?
  race               String?
  veteranStatus      String?
  disabilityStatus   String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ApplicationPassword {
  id                 String   @id @default(uuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  domain             String   // e.g. "myworkdayjobs.com"
  username           String
  encryptedPassword  String
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([userId, domain])
}

model Job {
  id             String   @id @default(uuid())
  title          String
  company        String
  location       String?
  description    String   @db.Text
  url            String
  atsPlatform    String   // e.g., "greenhouse", "workday"
  
  // Vector embedding of the job description for AI matching
  embedding      Unsupported("vector(1024)")? 
  
  postedAt       DateTime?
  createdAt      DateTime @default(now())

  applications   Application[]
  matches        JobMatch[]
}

model JobMatch {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  fitScore    Int      // 0-100
  reason      String   @db.Text
  gapAnalysis String?  @db.Text
  
  
  createdAt   DateTime @default(now())

  @@unique([userId, jobId])
}

model Application {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  status      String   @default("QUEUED") // QUEUED, APPLIED, FAILED, MANUAL_REVIEW
  appliedAt   DateTime?
  
  // Tailored materials specifically generated for this application
  tailoredResumeId String?
  tailoredCoverLetter String? @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Email {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromName    String?
  fromEmail   String
  subject     String
  bodyHtml    String   @db.Text
  bodyText    String   @db.Text
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}
